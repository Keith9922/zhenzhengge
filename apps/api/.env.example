ZHZG_APP_NAME=证证鸽 API
ZHZG_APP_VERSION=0.1.0
ZHZG_ENVIRONMENT=development
ZHZG_API_V1_PREFIX=/api/v1
ZHZG_DATABASE_URL=sqlite:///./data/zhenzhengge.db
ZHZG_CORS_ORIGINS=["http://localhost:3000","http://localhost:3006","http://127.0.0.1:3000","http://127.0.0.1:3006"]
ZHZG_CORS_ORIGIN_REGEX=^chrome-extension://.*$|^http://localhost:(3000|3001|3006)$|^http://127\\.0\\.0\\.1:(3000|3001|3006)$
ZHZG_ENABLE_DOCS=true
ZHZG_ENABLE_DEMO_SEED=false
ZHZG_REQUIRE_AUTH=true
ZHZG_AUTH_TOKENS=dev-admin-token:admin,dev-operator-token:operator,dev-viewer-token:viewer
ZHZG_EXTENSION_API_TOKEN=
ZHZG_LLM_PROVIDER=mimo
ZHZG_LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
ZHZG_LLM_API_KEY=
ZHZG_LLM_MODEL=mimo-v2-pro
ZHZG_LLM_REASONING_MODEL=o1-mini
ZHZG_LLM_TTS_MODEL=
ZHZG_SMTP_HOST=
ZHZG_SMTP_PORT=587
ZHZG_SMTP_USERNAME=
ZHZG_SMTP_PASSWORD=
ZHZG_SMTP_FROM_EMAIL=
ZHZG_SMTP_USE_TLS=true
ZHZG_MONITOR_SCHEDULER_ENABLED=true
ZHZG_MONITOR_SCHEDULER_INTERVAL_SECONDS=30
ZHZG_CAPTURE_ALLOW_HTTP_FALLBACK=true
ZHZG_DRAFT_GENERATION_STRICT=true
ZHZG_EVIDENCE_TIMESTAMP_ENABLED=false
ZHZG_EVIDENCE_TIMESTAMP_TSA_URL=
ZHZG_EVIDENCE_TIMESTAMP_TIMEOUT_SECONDS=15
ZHZG_EVIDENCE_TIMESTAMP_REQUIRED=false
# 本地已安装 hermes CLI 时将此项改为 true，否则自动回退到 LLM 直连
ZHZG_HARNESS_AGENT_ENABLED=true
ZHZG_HARNESS_CLI_COMMAND=hermes
ZHZG_HARNESS_PROVIDER=auto
ZHZG_HARNESS_MODEL=
ZHZG_HARNESS_TOOLSETS=skills,memory
ZHZG_HARNESS_SKILLS=hermes-agent,wps-word
ZHZG_HARNESS_TIMEOUT_SECONDS=120
