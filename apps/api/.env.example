ZHZG_APP_NAME=证证鸽 API
ZHZG_APP_VERSION=0.1.0
ZHZG_ENVIRONMENT=development
ZHZG_API_V1_PREFIX=/api/v1
ZHZG_DATABASE_URL=sqlite:///./data/zhenzhengge.db
ZHZG_CORS_ORIGINS=["http://localhost:3000"]
ZHZG_CORS_ORIGIN_REGEX=^chrome-extension://.*$|^http://localhost:(3000|3001)$|^http://127\\.0\\.0\\.1:(3000|3001)$
ZHZG_ENABLE_DOCS=true
ZHZG_LLM_PROVIDER=placeholder
ZHZG_OPENAI_API_KEY=
ZHZG_OPENAI_BASE_URL=https://api.openai.com/v1
ZHZG_OPENAI_MODEL=gpt-5.4-mini
ZHZG_OPENAI_REASONING_MODEL=gpt-5.4
ZHZG_SMTP_HOST=
ZHZG_SMTP_PORT=587
ZHZG_SMTP_USERNAME=
ZHZG_SMTP_PASSWORD=
ZHZG_SMTP_FROM_EMAIL=
ZHZG_SMTP_USE_TLS=true
