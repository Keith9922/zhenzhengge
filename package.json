{
  "name": "zhenzhengge",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "dev:extension": "pnpm --dir apps/extension dev",
    "build:extension": "pnpm --dir apps/extension build",
    "dev:api": "uv --directory apps/api run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "test:api": "uv --directory apps/api run pytest -q",
    "smoke:api": "uv --directory apps/api run python scripts/smoke_test.py"
  }
}
